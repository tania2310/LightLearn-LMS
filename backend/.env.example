# Django Configurations
SECRET_KEY=django-insecure-example-key-replace-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.herokuapp.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# Database Connection (PostgreSQL Sandbox)
DATABASE_URL=postgres://db_user:db_password@db_host:5432/db_name

# Email Host Configurations (SMTP Provider)
EMAIL_HOST_USER=example_user@gmail.com
EMAIL_HOST_PASSWORD=example_secret_smtp_password

# Simple JWT
JWT_SECRET=your-jwt-signing-secret

# Redis Configuration (Celery & Channels Broker)
REDIS_URL=redis://127.0.0.1:6379

# Third-party Integrations
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=paypal-client-id-here
PAYPAL_SECRET=paypal-client-secret-here
